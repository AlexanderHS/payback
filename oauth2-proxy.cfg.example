http_address = "127.0.0.1:4181"
upstreams = ["http://127.0.0.1:8104"]

provider = "google"
client_id = "REPLACE_WITH_GOOGLE_CLIENT_ID"
client_secret = "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
redirect_url = "https://your.domain.example/oauth2/callback"
scope = "openid email profile"

# Generate with: openssl rand -base64 32 | tr -d '=+/' | cut -c1-32
cookie_secret = "REPLACE_WITH_RANDOM_32_CHAR_STRING"
cookie_secure = true
cookie_name = "_payback_oauth2"

# Allow any Google account to sign in. Per-user data isolation in the app
# means a new user lands on their own empty dashboard.
# To restrict instead, set email_domains = [] and uncomment authenticated_emails_file:
email_domains = ["*"]
# authenticated_emails_file = "/etc/oauth2-proxy/allowed-emails.txt"

# Pass user identity to upstream
set_xauthrequest = true
pass_user_headers = true

# Skip the "Sign in with Google" interstitial
skip_provider_button = true

# Silence noisy logs
silence_ping_logging = true

# Bypass oauth2-proxy auth for:
#   /              public marketing landing page (logged-in users redirect to /dashboard via JS)
#   /privacy       public privacy page
#   /static/       CSS, fonts, etc. (the landing page references these unauthenticated)
#   /oauth2/       oauth2-proxy's own endpoints, including /oauth2/auth used by the
#                  landing-page JS to detect already-signed-in visitors
#   /api/*         Flask handles Bearer-token auth itself
#   /docs          public read-only reference; LLM agents need to read it pre-auth.
skip_auth_routes = ["^/$", "^/privacy$", "^/static/", "^/api/", "^/docs$"]
