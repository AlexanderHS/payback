# Required: stable across container restarts so CSRF tokens survive.
# Generate with: openssl rand -base64 48 | tr -d '=+/'
SECRET_KEY=replace-with-long-random-string

# Optional but recommended: separate token for the privacy-preserving
# /api/analytics endpoint. Empty value = endpoint refuses everything.
# Generate with: openssl rand -base64 48 | tr -d '=+/'
ANALYTICS_TOKEN=replace-with-another-long-random-string
